{
  "info": {
    "name": "SmartShoppingAssistant API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5221"
    },
    {
      "key": "createdProductId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Get All Products",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is an array\", function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Seed data exists - at least 4 products\", function () {",
              "    pm.expect(pm.response.json().length).to.be.at.least(4);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Product by ID",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has id, name, price\", function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json).to.have.property('name');",
              "    pm.expect(json).to.have.property('price');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Product by ID - Not Found",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products/999"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Product",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/products",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Product\",\n  \"description\": \"Produs de test creat via Postman\",\n  \"price\": 9.99,\n  \"imageUrl\": null\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response has id\", function () {",
              "    pm.expect(pm.response.json()).to.have.property('id');",
              "});",
              "",
              "pm.test(\"Name este corect\", function () {",
              "    pm.expect(pm.response.json().name).to.eql('Test Product');",
              "});",
              "",
              "if (pm.response.code === 201) {",
              "    pm.collectionVariables.set('createdProductId', pm.response.json().id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Update Product",
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/api/products/{{createdProductId}}",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Product Updated\",\n  \"description\": \"Descriere actualizata\",\n  \"price\": 14.99,\n  \"imageUrl\": null\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Numele a fost actualizat\", function () {",
              "    pm.expect(pm.response.json().name).to.eql('Test Product Updated');",
              "});",
              "",
              "pm.test(\"Pretul a fost actualizat\", function () {",
              "    pm.expect(pm.response.json().price).to.eql(14.99);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete Product",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/products/{{createdProductId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 204\", function () {",
              "    pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Deleted Product - Not Found",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products/{{createdProductId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Produsul sters returneaza 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
